{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "id": null,
  "uid": "canary-cicd-2026",
  "title": "Canary CI/CD — Tekton + Argo CD",
  "description": "Dashboard para monitorear el flujo completo de canary deployment: split de tráfico, réplicas, logs y estado del pipeline.",
  "tags": ["canary", "tekton", "argocd", "gitops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "🚦 Traffic Split",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "type": "gauge",
      "title": "Canary Traffic % (v2 verde)",
      "description": "Porcentaje de pods canary respecto al total webapp",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-canary\"} / (kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-canary\"} + kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-stable\"} > 0) * 100",
          "legendFormat": "Canary %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 10, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 90, "color": "orange" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },

    {
      "id": 3,
      "type": "gauge",
      "title": "Stable Traffic % (v1 azul)",
      "description": "Porcentaje de pods stable respecto al total webapp",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-stable\"} / (kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-canary\"} + kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=\"webapp-stable\"} > 0) * 100",
          "legendFormat": "Stable %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "blue" },
              { "value": 90, "color": "dark-blue" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Pods Canary (v2)",
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"canary-demo\", deployment=\"webapp-canary\"}",
          "legendFormat": "canary ready",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto"
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Pods Stable (v1)",
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"canary-demo\", deployment=\"webapp-stable\"}",
          "legendFormat": "stable ready",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto"
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Total Pods webapp",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_ready{namespace=\"canary-demo\", deployment=~\"webapp-.*\"})",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "background"
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Load Generator",
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"canary-demo\", deployment=\"load-generator\"}",
          "legendFormat": "load-gen",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "background"
      }
    },

    {
      "id": 8,
      "type": "row",
      "title": "📈 Réplicas — Estado GitOps",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Réplicas por Deployment (spec)",
      "description": "Réplicas deseadas — cambia cuando Argo CD sincroniza el git push de Tekton",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_spec_replicas{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}",
          "legendFormat": "{{deployment}} (spec)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": []
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Réplicas Ready (status)",
      "description": "Réplicas realmente disponibles en el cluster",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}",
          "legendFormat": "{{deployment}} (ready)",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_status_replicas_unavailable{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}",
          "legendFormat": "{{deployment}} (unavailable)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 11,
      "type": "row",
      "title": "🌐 Tráfico HTTP — Linkerd Service Mesh",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Request Rate (req/seg) por deployment",
      "description": "Requests HTTP reales medidos por el proxy Linkerd en cada pod",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(request_total{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}[1m])) by (deployment)",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Success Rate (%) por deployment",
      "description": "Porcentaje de respuestas exitosas medido por Linkerd",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(response_total{namespace=\"canary-demo\", classification=\"success\", deployment=~\"webapp-.*\"}[1m])) by (deployment) / sum(rate(response_total{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}[1m])) by (deployment) * 100",
          "legendFormat": "{{deployment}} success%",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 95, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Latencia P50 / P99 (ms)",
      "description": "Latencia de respuesta medida por Linkerd proxy",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(response_latency_ms_bucket{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}[1m])) by (le, deployment))",
          "legendFormat": "{{deployment}} P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(response_latency_ms_bucket{namespace=\"canary-demo\", deployment=~\"webapp-.*\"}[1m])) by (le, deployment))",
          "legendFormat": "{{deployment}} P99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 15,
      "type": "row",
      "title": "📋 Logs — Loki",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 }
    },

    {
      "id": 16,
      "type": "logs",
      "title": "Logs — webapp-canary (v2 🟩)",
      "description": "Logs del pod canary — aparecen cuando replica > 0",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{namespace=\"canary-demo\", version=\"canary\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },

    {
      "id": 17,
      "type": "logs",
      "title": "Logs — webapp-stable (v1 🟦)",
      "description": "Logs del pod stable — siempre activo",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{namespace=\"canary-demo\", version=\"stable\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },

    {
      "id": 18,
      "type": "logs",
      "title": "Logs — Load Generator (tráfico entrante)",
      "description": "Peticiones HTTP que hace el load-generator cada segundo",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{namespace=\"canary-demo\", app=\"load-generator\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },

    {
      "id": 19,
      "type": "row",
      "title": "⚙️ Estado CI/CD — Tekton & Argo CD",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 1 }
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Pods por namespace tekton-pipelines",
      "description": "Pods de Tekton — picos cuando corre el pipeline",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"tekton-pipelines\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Pods canary-demo — todas las versiones",
      "description": "Total de pods corriendo — sube/baja con cada fase del canary",
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"canary-demo\", phase=\"Running\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    }

  ],

  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "label": "Loki",
        "current": {}
      }
    ]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
